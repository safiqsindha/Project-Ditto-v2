# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Anthropic API key for model evaluations (Sessions 12–13)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: HuggingFace token for dataset access (Sessions 2–3)
# Needed if Terminal-Bench or SWE-bench datasets are gated on HuggingFace Hub.
# HF_TOKEN=your-hf-token-here
